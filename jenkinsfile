pipeline {
    agent any
    
    environment {
        AWS_REGION = 'us-east-1'
        CLUSTER_NAME = 'k8'
        ECR_REPO = 'test'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        
         stage('Set AWS Account ID') {
            steps {
                script {
                    env.ACCOUNT_ID = sh(
                        script: "aws sts get-caller-identity --query Account --output text",
                        returnStdout: true
                    ).trim()
                }
            }
        }
        
        stage('git checkout') {
            steps {
               git branch: 'main', url: 'https://github.com/shubham-2143/Jenkins-CI-CD-with-K8-deployment.git'
            }
        }
        
        stage('build docker image') {
            steps {
                sh " docker build -t $ECR_REPO:$IMAGE_TAG ./app"
            }
        }
        
        stage('ECR Login') {
            steps {
                sh '''
                aws ecr get-login-password \
                --region $AWS_REGION | docker login \
                --username AWS \
                --password-stdin \
                $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                '''
            }
        }
        
         stage('Push Image to ECR') {
            steps {
                sh '''
                docker tag $ECR_REPO:$IMAGE_TAG \
                $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPO:$IMAGE_TAG

                docker push \
                $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/$ECR_REPO:$IMAGE_TAG
                '''
            }
        }
        
         stage('Configure EKS') {
            steps {
                sh '''
                aws eks update-kubeconfig \
                --region $AWS_REGION \
                --name $CLUSTER_NAME
                '''
            }
        }
        
        stage('Deploy to EKS') {
            steps {
                sh '''
                sed -i 's|IMAGE_URI|'"$ACCOUNT_ID"'.dkr.ecr.'"$AWS_REGION"'.amazonaws.com/'"$ECR_REPO"':'"$IMAGE_TAG"'|g' k8s/deploy.yaml

                kubectl apply -f k8s/deploy.yaml
                kubectl apply -f k8s/service.yaml
                '''
            }
        }

        stage('Verify') {
            steps {
                sh '''
                kubectl get pods
                kubectl get svc
                '''
            }
        }
    }
}
